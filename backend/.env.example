# Copy to .env and edit. All settings are optional; sane defaults are used
# if omitted (see app/config.py).

# Folder to ingest markdown notes from.
PKG_NOTES_DIR=/path/to/your/notes

# Where the SQLite database file is stored.
PKG_DB_PATH=./data/pkg.db

# "local" (default, private, free) or "openai" (better quality, costs $, needs internet)
PKG_EMBEDDING_PROVIDER=local
PKG_LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Only needed if PKG_EMBEDDING_PROVIDER=openai
PKG_OPENAI_API_KEY=
PKG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
